# -----------------------------
# Docker Compose Runtime Config
# -----------------------------

# Exposed ports
FRONTEND_PORT=13000
BACKEND_PORT=18000
POSTGRES_PORT=55432
LOGISTICS_PORT=18010

# App env
APP_ENV=production
APP_CORS_ORIGINS=http://localhost:13000

# PostgreSQL
POSTGRES_DB=lumera
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend database url (container-to-container)
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/lumera

# Backend -> logistics service
LOGISTICS_SERVICE_ENABLED=true
LOGISTICS_SERVICE_BASE_URL=http://logistics:8010/api/v1/logistics
LOGISTICS_SERVICE_TIMEOUT_SECONDS=8

# Frontend public api url (browser-side)
NEXT_PUBLIC_API_BASE_URL=http://localhost:18000/api/v1
NEXT_INTERNAL_API_BASE_URL=http://app:8000/api/v1

# Optional admin defaults
ADMIN_DEFAULT_EMAIL=xwq
ADMIN_DEFAULT_PASSWORD=xwq20001228
ADMIN_JWT_SECRET=change-this-in-production

# Backend startup behavior
RUN_MIGRATIONS=1
DB_WAIT_TIMEOUT=60
MEDIA_MAX_UPLOAD_SIZE_MB=20
MEDIA_MAX_VIDEO_UPLOAD_SIZE_MB=30
SYNC_ADMIN_ON_START=1

# Optional: logistics db (defaults to sqlite if empty)
# LOGISTICS_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/lumera_logistics
